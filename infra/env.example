# コピーして .env を作成: cp env.example .env

# --- PostgreSQL ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=linuxtrainer
# アプリからの接続（docker compose 内のサービス名 postgres をホストに）
DATABASE_URL=postgresql://app:${POSTGRES_PASSWORD}@postgres:5432/linuxtrainer

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- アプリ（フェーズ6で実装時に使用）---
# API / WebSocket をリッスンするポート（Nginx upstream と一致させる）
API_PORT=3001
# Next.js 等フロント（任意）
WEB_PORT=3000

# --- TLS（本番は ACM / Let's Encrypt 等に差し替え）---
# Nginx が参照する証明書パス（コンテナ内は /etc/nginx/certs にマウント）
TLS_CERT_PATH=./nginx/certs/server.crt
TLS_KEY_PATH=./nginx/certs/server.key
