NODE_ENV=development
# 本番で Nginx 等の背後に置く場合は true（クライアント IP・レート制限用）
TRUST_PROXY=false
HOST=0.0.0.0
PORT=3001
DATABASE_URL=postgresql://app:change_me@127.0.0.1:5432/linuxtrainer
REDIS_URL=redis://127.0.0.1:6379
# ログイン試行制限（同一 IP・失敗回数が上限に達するとロックアウト）
LOGIN_RATE_MAX_ATTEMPTS=10
LOGIN_RATE_WINDOW_SEC=900
# /api 全体の 1 分あたり上限（health / ready は除外）
API_RATE_MAX_PER_MIN=400
SESSION_COOKIE_NAME=session_id
SESSION_TTL_SEC=28800
# フロントのオリジン（CORS）。Next.js 開発時は例:
# FRONTEND_ORIGIN=http://127.0.0.1:3000
DOCKER_SOCKET_PATH=/var/run/docker.sock
LEARNER_IMAGE=linuxtrainer-learner:latest
# 研修コンテナのネットワーク: bridge=dnf 等で外部に到達可 / none=隔離（DNS 不可）
LEARNER_CONTAINER_NETWORK_MODE=bridge
IDLE_WARN_SEC=1200
IDLE_DISCONNECT_SEC=1800
# ターミナル未接続で最終アクセスからこの秒数経過後にコンテナ削除（0=無効）。デフォルト 3600
LEARNER_CONTAINER_IDLE_RELEASE_SEC=3600
